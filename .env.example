# 运行模式：cloud | local
APP_ENV=local

# GCP 配置（cloud 模式使用）
GCP_PROJECT_ID=pushgamiltogithub
GMAIL_TOKEN_SECRET=gmail_token_json
WATCH_TOPIC_NAME=projects/pushgamiltogithub/topics/gmailtocloud

# 本地文件配置（local 模式使用）
GMAIL_TOKEN_FILE=secrets/gmail_token.json
STATE_BACKEND=file
LOCAL_STATE_FILE=data/last_history_id.json
DEFAULT_HISTORY_ID=50702

# 可选功能
ENABLE_WATCH_REFRESH_EMAIL=false
GITHUB_TOKEN=
EMAIL_ADDRESS_QQ=
EMAIL_PASSWORD_QQ=
FORWARD_EMAIL=
